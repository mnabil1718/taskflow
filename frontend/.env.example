# -------------------------------------------------------------------------
# TaskFlow frontend — environment variable reference
#
# For local development (outside Docker):
#   cp frontend/.env.example frontend/.env.local
#
# When using Docker Compose this value is injected at build time as a build
# ARG, so no .env.local file is needed to run `docker compose up`.
# -------------------------------------------------------------------------

# Base URL of the backend API (must include /api/v1).
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
