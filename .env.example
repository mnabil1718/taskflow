# Required for docker compose — copy to .env and fill in JWT secrets:
#   cp .env.example .env

# App
APP_PORT=8080
APP_ENV=development
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=taskflow
DB_PASSWORD=taskflow
DB_NAME=taskflow
DB_SSLMODE=disable

# JWT (required — must be set before running)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h
