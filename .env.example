# Backend environment variables.
# Copy this file to `.env` (in the backend working directory) for local,
# non-Docker development. The Docker Compose stack injects these values itself,
# so you do NOT need a .env file to run `docker compose up`.

# --- App ---

# Port the HTTP server listens on.
APP_PORT=8080

# Runtime mode: "development" or "production".
# development -> debug-level text logs, and demo data is seeded automatically.
# production  -> info-level JSON logs, no automatic seeding (see APP_SEED).
APP_ENV=development

# Seed demo data (2 users, 2 projects, 5 tasks) on startup. Always seeded in
# development; set to true to also seed in production (the Compose stack does
# this). The seeder is idempotent and skips if the data already exists.
APP_SEED=false

# Comma-separated list of origins allowed by CORS (the frontend URL).
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Database (PostgreSQL) ---

# Host of the Postgres server. Use "localhost" when running the binary
# directly; the Compose backend uses the service name "db".
DB_HOST=localhost

# Port of the Postgres server.
DB_PORT=5432

# Database username.
DB_USER=taskflow

# Database password.
DB_PASSWORD=taskflow

# Database name.
DB_NAME=taskflow

# TLS mode for the connection: disable | require | verify-ca | verify-full.
DB_SSLMODE=disable

# --- JWT ---

# Secrets used to sign access and refresh tokens. REQUIRED — the server refuses
# to start if either is empty. Use long, random, distinct values. Generate one
# with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace-with-a-32-byte-random-hex-string
JWT_REFRESH_SECRET=replace-with-a-different-32-byte-random-hex-string

# Access token lifetime (Go duration, e.g. 15m).
JWT_ACCESS_EXPIRY=15m

# Refresh token lifetime (Go duration, e.g. 168h = 7 days).
JWT_REFRESH_EXPIRY=168h
