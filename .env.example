# Run `make up` — it creates .env automatically with random JWT secrets.
# To set up manually: cp .env.example .env  (then fill in JWT secrets)

# App
APP_PORT=8080
APP_ENV=development
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=taskflow
DB_PASSWORD=taskflow
DB_NAME=taskflow
DB_SSLMODE=disable

# JWT (required — must be set before running)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h
