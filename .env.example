# -------------------------------------------------------------------------
# TaskFlow — environment variable reference
#
# Docker Compose (zero-config, recommended):
#   docker compose up
#   Works out of the box. JWT secrets fall back to built-in demo values
#   that are safe for local use. No .env file required.
#
# Override Docker JWT secrets (optional):
#   cp .env.example .env
#   Fill in JWT_ACCESS_SECRET and JWT_REFRESH_SECRET with strong values,
#   then run: docker compose up
#
# Local backend development (running the binary directly, not via Docker):
#   cp .env.example backend/.env
#   Adjust DB_HOST/DB_PORT to point at your local Postgres instance.
#
# Local frontend development:
#   cp frontend/.env.example frontend/.env.local
# -------------------------------------------------------------------------

# --- App ---

# Port the HTTP server listens on.
APP_PORT=8080

# Runtime mode: "development" or "production".
# development -> debug-level text logs; demo data is seeded automatically.
# production  -> info-level JSON logs; seeding only when APP_SEED=true.
APP_ENV=development

# Seed demo data (2 users, 2 projects, 5 tasks) on startup.
# Always seeded in development. Set to true to seed in production.
# The seeder is idempotent and skips if the data already exists.
APP_SEED=false

# Comma-separated list of origins allowed by CORS (the frontend URL).
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Relative path to the migrations directory from the binary's working dir.
MIGRATIONS_PATH=migrations

# --- Database (PostgreSQL) ---

DB_HOST=localhost
DB_PORT=5432
DB_USER=taskflow
DB_PASSWORD=taskflow
DB_NAME=taskflow

# TLS mode: disable | require | verify-ca | verify-full
DB_SSLMODE=disable

# --- JWT ---
# REQUIRED — the server refuses to start if either value is empty.
# Generate a secret with: openssl rand -hex 32
# Use distinct values for access and refresh.
JWT_ACCESS_SECRET=replace-with-a-32-byte-random-hex-string
JWT_REFRESH_SECRET=replace-with-a-different-32-byte-random-hex-string

# Access token lifetime (Go duration syntax).
JWT_ACCESS_EXPIRY=15m

# Refresh token lifetime (Go duration syntax, 168h = 7 days).
JWT_REFRESH_EXPIRY=168h
